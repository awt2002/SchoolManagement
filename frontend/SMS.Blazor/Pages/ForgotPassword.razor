@page "/forgot-password"
@inject SMS.Blazor.Services.AuthHttpService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Forgot Password - SMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 80vh;">
    <MudPaper Elevation="3" Class="pa-8 mx-auto" Style="width: 100%; max-width: 420px;">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Forgot Password</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">Enter your email or username to receive a password reset link.</MudText>

        <MudTextField @bind-Value="_emailOrUsername" Label="Email or Username" Variant="Variant.Outlined" Class="mb-4" />

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="@SendResetLink" Class="mb-2">
            Send Password Reset Link
        </MudButton>

        <MudButton Variant="Variant.Text" Color="Color.Secondary" FullWidth="true" OnClick="@(() => Navigation.NavigateTo("/login"))">
            Back to Login
        </MudButton>

    </MudPaper>
</MudContainer>

@code {
    private string _emailOrUsername = string.Empty;

    private async Task SendResetLink()
    {
        if (string.IsNullOrWhiteSpace(_emailOrUsername))
        {
            Snackbar.Add("Please enter your email or username", Severity.Warning);
            return;
        }

        try
        {
            var result = await AuthService.ForgotPasswordAsync(new ForgotPasswordRequestDto
            {
                Email = _emailOrUsername
            });

            if (result?.Success == true)
            {
                Snackbar.Add(result.Message, Severity.Info);
                Navigation.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add(result?.Message ?? "Failed to send reset link", Severity.Error);
            }
        }
        catch
        {
            Snackbar.Add("An error occurred. Please try again.", Severity.Error);
        }
    }
}

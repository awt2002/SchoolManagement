@page "/reset-password"
@inject SMS.Blazor.Services.AuthHttpService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Reset Password - SMS</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center" Style="min-height: 80vh;">
    <MudPaper Elevation="3" Class="pa-8 mx-auto" Style="width: 100%; max-width: 420px;">
        <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-4">Reset Password</MudText>

        <MudTextField @bind-Value="_newPassword" Label="New Password" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mb-3" />
        <MudTextField @bind-Value="_confirmNewPassword" Label="Confirm New Password" Variant="Variant.Outlined"
                      InputType="InputType.Password" Class="mb-2" />

        <MudText Typo="Typo.caption" Class="mb-4 d-block">Password must be at least 8 characters and include 1 uppercase letter and 1 number.</MudText>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="@HandleReset">
            Reset Password
        </MudButton>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmNewPassword = string.Empty;

    private async Task HandleReset()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            Snackbar.Add("Invalid reset link", Severity.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword) || string.IsNullOrWhiteSpace(_confirmNewPassword))
        {
            Snackbar.Add("Please fill in all fields", Severity.Warning);
            return;
        }

        var result = await AuthService.ResetPasswordAsync(new ResetPasswordDto
        {
            Token = Token,
            NewPassword = _newPassword,
            ConfirmNewPassword = _confirmNewPassword
        });

        if (result?.Success == true)
        {
            Snackbar.Add("Password reset successfully. Please log in.", Severity.Success);
            Navigation.NavigateTo("/login");
        }
        else
        {
            Snackbar.Add(result?.Message ?? "Failed to reset password", Severity.Error);
        }
    }
}

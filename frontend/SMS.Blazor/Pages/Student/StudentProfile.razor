@page "/student/profile"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Student")]
@inject SMS.Blazor.Services.StudentHttpService StudentService

<PageTitle>My Profile - SMS</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">My Profile</MudText>

@if (_student != null)
{
    <MudPaper Elevation="2" Class="pa-4">
        <MudGrid>
            <MudItem xs="12" md="3">
                @if (!string.IsNullOrEmpty(_student.PhotoUrl))
                {
                    <MudAvatar Size="Size.Large" Style="width:120px;height:120px;">
                        <MudImage Src="@_student.PhotoUrl" />
                    </MudAvatar>
                }
                else
                {
                    <MudAvatar Size="Size.Large" Color="Color.Primary" Style="width:120px;height:120px;">
                        @_student.FullName.Substring(0, 1)
                    </MudAvatar>
                }
            </MudItem>
            <MudItem xs="12" md="9">
                <MudText Typo="Typo.h5">@_student.FullName</MudText>
                <MudText><strong>Date of Birth:</strong> @_student.DateOfBirth</MudText>
                <MudText><strong>Address:</strong> @_student.Address</MudText>
                <MudText><strong>Enrollment Year:</strong> @_student.EnrollmentYear</MudText>
                <MudText><strong>Status:</strong>
                    @if (_student.IsActive)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Error" Size="Size.Small">Inactive</MudChip>
                    }
                </MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @if (_student.Enrollments.Count > 0)
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-2">Enrollment History</MudText>
        <MudTable Items="@_student.Enrollments" Hover="true" Elevation="2">
            <HeaderContent>
                <MudTh>Class</MudTh>
                <MudTh>Academic Year</MudTh>
                <MudTh>Enrolled At</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.ClassName</MudTd>
                <MudTd>@context.AcademicYearName</MudTd>
                <MudTd>@context.EnrolledAt.ToString("d")</MudTd>
            </RowTemplate>
        </MudTable>
    }
}
else
{
    <MudAlert Severity="Severity.Info">Loading profile...</MudAlert>
}

@code {
    private StudentDetailDto? _student;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await StudentService.GetMyProfileAsync();
            _student = result?.Data;
        }
        catch { }
    }
}

@inject SMS.Blazor.Services.AnnouncementHttpService AnnouncementService
@inject NavigationManager Navigation

<MudTooltip Text="Notifications">
    <MudBadge Content="@_unreadCount" Visible="@(_unreadCount > 0)" Color="Color.Error" Overlap="true">
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit"
                       OnClick="@GoToAnnouncements" />
    </MudBadge>
</MudTooltip>

@code {
    private int _unreadCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var result = await AnnouncementService.GetUnreadCountAsync();
            if (result?.Data != null)
            {
                _unreadCount = result.Data.Count;
            }
        }
        catch { }
    }

    private void GoToAnnouncements()
    {
        Navigation.NavigateTo("/announcements");
    }
}
